---
// About Section - Clean & Personal
---

<section id="about" class="about-section py-24 px-6 bg-white">
  <div class="container mx-auto max-w-5xl">
    <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-16 text-center">
      À Propos
    </h2>

    <div class="about-content grid md:grid-cols-2 gap-12 items-center">
      <!-- Photo placeholder -->
      <div class="photo-container">
        <div 
          class="photo-placeholder w-full aspect-square rounded-2xl shadow-xl
                 transition-all duration-500 hover:scale-105 relative overflow-hidden
                 bg-gradient-to-br from-accent-primary via-accent-coral to-accent-secondary"
          role="img"
          aria-label="Photo d'Isabelle"
        >
          <div class="flex items-center justify-center h-full text-white text-6xl font-bold relative z-10">
            I
          </div>
          <!-- Animated border gradient -->
          <div class="absolute inset-0 border-4 border-transparent rounded-2xl photo-border"></div>
        </div>
      </div>

      <!-- Bio -->
      <div class="bio-content space-y-6 text-lg text-text-secondary">
        <p class="leading-relaxed">
          Assistante caméra dans l'audiovisuel, puis reconversion via Le Wagon en 2020 — 
          mais geek depuis <strong class="text-text-primary font-semibold">1995</strong> et le HTML à la main.
        </p>
        
        <p class="leading-relaxed">
          Développeuse Rails <strong class="text-text-primary font-semibold">passionnée par l'accessibilité web</strong>, 
          je construis des outils qui servent des millions de personnes — et j'y pense peut-être un peu trop.
        </p>

        <div class="current-role space-y-2">
          <p class="text-text-primary font-semibold">Actuellement:</p>
          <p><strong>DataPass</strong> - Plateforme gouvernementale OpenSource (DINUM)</p>
        </div>

        <div class="mission space-y-2">
          <p class="text-text-primary font-semibold">Mission:</p>
          <p>
            Rendre le web gouvernemental accessible à tous, 
            <span class="text-accent-primary font-medium">parce que c'est un droit</span>.
          </p>
        </div>

        <div class="stack space-y-3">
          <p class="text-text-primary font-semibold">Stack:</p>
          <div class="flex flex-wrap gap-2">
            <span class="stack-tag px-4 py-2 bg-gray-100 rounded-full text-sm font-mono hover:bg-accent-primary hover:text-white transition-colors duration-200">
              Rails
            </span>
            <span class="stack-tag px-4 py-2 bg-gray-100 rounded-full text-sm font-mono hover:bg-accent-primary hover:text-white transition-colors duration-200">
              PostgreSQL
            </span>
            <span class="stack-tag px-4 py-2 bg-gray-100 rounded-full text-sm font-mono hover:bg-accent-primary hover:text-white transition-colors duration-200">
              Hotwire
            </span>
            <span class="stack-tag px-4 py-2 bg-gray-100 rounded-full text-sm font-mono hover:bg-accent-primary hover:text-white transition-colors duration-200">
              Docker
            </span>
          </div>
        </div>

        <button 
          class="fun-fact mt-8 p-4 bg-accent-coral/10 border-l-4 border-accent-coral rounded-r-lg
                 transition-all duration-300 hover:bg-accent-coral/20 hover:scale-105
                 w-full text-left relative overflow-hidden"
          onclick="celebrateBots()"
          aria-label="Cliquez pour célébrer les bots!"
        >
          <p class="text-text-primary">
            <strong class="font-semibold">Fun fact:</strong> 
            Portfolio codé en 10 minutes par mes assistants IA Owly 🦉, Bender 🤖 et Data 🖖
            <span class="text-xs text-text-secondary ml-2">(cliquez-moi!)</span>
          </p>
          <div class="confetti-container absolute inset-0 pointer-events-none"></div>
        </button>

        <script>
          function celebrateBots() {
            const container = event.currentTarget.querySelector('.confetti-container');
            
            // Create confetti
            for (let i = 0; i < 30; i++) {
              const confetti = document.createElement('div');
              const emojis = ['🦉', '🤖', '🖖', '✨', '🎉', '💫'];
              confetti.textContent = emojis[Math.floor(Math.random() * emojis.length)];
              confetti.style.position = 'absolute';
              confetti.style.left = Math.random() * 100 + '%';
              confetti.style.top = '50%';
              confetti.style.fontSize = '20px';
              confetti.style.animation = `confettiFall ${1 + Math.random()}s ease-out forwards`;
              confetti.style.opacity = '0';
              
              container.appendChild(confetti);
              
              // Remove after animation
              setTimeout(() => confetti.remove(), 1500);
            }
          }
        </script>

        <style>
          @keyframes confettiFall {
            0% {
              opacity: 1;
              transform: translateY(0) rotate(0deg);
            }
            100% {
              opacity: 0;
              transform: translateY(-100px) rotate(360deg);
            }
          }
        </style>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
  }

  /* Scroll reveal animation */
  .about-content {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Photo gradient animation */
  .photo-placeholder {
    background-size: 200% 200%;
    animation: gradientRotate 10s ease infinite;
  }

  @keyframes gradientRotate {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* Border gradient on hover */
  .photo-border {
    background: linear-gradient(
      45deg,
      var(--accent-primary),
      var(--accent-coral),
      var(--accent-secondary),
      var(--accent-primary)
    );
    background-size: 300% 300%;
    animation: borderGlow 3s ease infinite;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .photo-placeholder:hover .photo-border {
    opacity: 0.6;
  }

  @keyframes borderGlow {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-content {
      animation: none;
      opacity: 1;
    }

    .photo-placeholder,
    .photo-border {
      animation: none;
      transition: none;
    }

    .stack-tag {
      transition: none;
    }
  }
</style>
