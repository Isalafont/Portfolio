---
// Hero Section - Adham style (clean) + Cassie micro-interactions
---

<section class="hero-section min-h-screen flex flex-col items-center justify-center px-6 relative overflow-hidden">
  <!-- Split Background Zones -->
  <div class="split-zone split-left absolute top-0 left-0 w-1/2 h-full"></div>
  <div class="split-zone split-right absolute top-0 right-0 w-1/2 h-full"></div>
  
  <!-- Code Symbols (Left) -->
  <div class="symbols-left absolute left-0 top-0 w-1/2 h-full flex items-center justify-center pointer-events-none">
    <div class="symbols-container">
      <div class="symbol symbol-1" style="font-size: 120px; opacity: 0.08; color: #667EEA; position: absolute; top: 20%; left: 15%;">&lt;/&gt;</div>
      <div class="symbol symbol-2" style="font-size: 60px; opacity: 0.06; color: #667EEA; position: absolute; top: 60%; left: 25%; font-family: monospace;">{ }</div>
      <div class="symbol symbol-3" style="font-size: 50px; opacity: 0.05; color: #667EEA; position: absolute; top: 40%; left: 35%; font-family: monospace;">=&gt;</div>
    </div>
  </div>
  
  <!-- Accessibility Symbols (Right) -->
  <div class="symbols-right absolute right-0 top-0 w-1/2 h-full flex items-center justify-center pointer-events-none">
    <div class="symbols-container">
      <div class="symbol symbol-4" style="font-size: 100px; opacity: 0.08; color: #EC4899; position: absolute; top: 25%; right: 20%;">♿</div>
      <div class="symbol symbol-5" style="font-size: 70px; opacity: 0.06; color: #EC4899; position: absolute; top: 55%; right: 15%;">⚡</div>
      <div class="symbol symbol-6" style="font-size: 60px; opacity: 0.05; color: #10B981; position: absolute; top: 70%; right: 30%;">✓</div>
    </div>
  </div>

  <div class="hero-content text-center max-w-4xl relative z-10">
    <!-- Main Heading with Wave -->
    <h1 class="hero-title text-5xl md:text-7xl font-bold mb-6 text-text-primary">
      Hi! Je suis Isabelle <span class="wave" aria-hidden="true">👋</span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-subtitle text-xl md:text-2xl text-text-secondary mb-4 font-medium">
      Développeuse Rails • Expert Accessibilité
    </p>

    <!-- Description -->
    <p class="hero-description text-lg md:text-xl text-text-secondary mb-12 max-w-2xl mx-auto">
      Je construis des applications web à fort impact — accessibles à tous, sans exception.
    </p>

    <!-- CTA Buttons -->
    <div class="cta-buttons flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a 
        href="#projects" 
        class="btn-primary group px-8 py-4 bg-accent-primary text-white rounded-lg font-medium text-lg
               transition-all duration-300 ease-out
               hover:shadow-xl hover:-translate-y-1 hover:shadow-accent-primary/30
               focus-visible:outline-accent-primary"
      >
        Voir mes projets
      </a>
      
      <a 
        href="#contact" 
        class="btn-secondary group px-8 py-4 border-2 border-accent-primary text-accent-primary rounded-lg font-medium text-lg
               transition-all duration-300 ease-out
               hover:bg-accent-primary hover:text-white hover:shadow-xl hover:-translate-y-1
               focus-visible:outline-accent-primary"
      >
        Me contacter
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <a 
    href="#about" 
    class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 focus-visible:outline-accent-primary rounded-lg p-2"
    aria-label="Défiler vers la section À propos"
  >
    <svg 
      class="scroll-bounce w-6 h-6 text-accent-primary"
      fill="none" 
      stroke="currentColor" 
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        stroke-width="2" 
        d="M19 14l-7 7m0 0l-7-7m7 7V3"
      />
    </svg>
  </a>
</section>

<style>
  .hero-section {
    background: #FAFAFA;
    position: relative;
  }

  /* Split Zones with subtle gradient */
  .split-left {
    background: linear-gradient(
      to right,
      rgba(102, 126, 234, 0.08) 0%,
      rgba(102, 126, 234, 0.03) 70%,
      transparent 100%
    );
  }

  .split-right {
    background: linear-gradient(
      to left,
      rgba(236, 72, 153, 0.08) 0%,
      rgba(236, 72, 153, 0.03) 70%,
      transparent 100%
    );
  }

  /* Text stagger animation */
  .hero-title,
  .hero-subtitle,
  .hero-description,
  .cta-buttons {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .hero-title {
    animation-delay: 0.1s;
  }

  .hero-subtitle {
    animation-delay: 0.2s;
  }

  .hero-description {
    animation-delay: 0.3s;
  }

  .cta-buttons {
    animation-delay: 0.4s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Disable animations for reduced motion */
  /* Subtle floating animation for symbols */
  .symbol {
    animation: subtleFloat 8s ease-in-out infinite;
  }

  .symbol-1 { animation-delay: 0s; }
  .symbol-2 { animation-delay: 1s; }
  .symbol-3 { animation-delay: 2s; }
  .symbol-4 { animation-delay: 0.5s; }
  .symbol-5 { animation-delay: 1.5s; }
  .symbol-6 { animation-delay: 2.5s; }

  @keyframes subtleFloat {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-subtitle,
    .hero-description,
    .cta-buttons {
      animation: none;
      opacity: 1;
    }

    .wave {
      animation: none;
    }

    .scroll-bounce {
      animation: none;
    }

    .btn-primary,
    .btn-secondary {
      transition: none;
    }

    .symbol {
      animation: none;
    }
  }

  /* Screen reader only class */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
