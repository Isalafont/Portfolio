---
// Navigation Header - Minimal & Accessible
---

<header class="header fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
  <nav class="container mx-auto px-6 py-4" aria-label="Navigation principale">
    <div class="nav-content flex items-center justify-between">
      <!-- Logo / Name -->
      <a 
        href="#top" 
        class="logo text-2xl font-bold text-text-primary hover:text-accent-primary transition-colors duration-200"
      >
        Isabelle
      </a>

      <!-- Desktop Navigation -->
      <ul class="nav-links hidden md:flex items-center gap-8">
        <li>
          <a 
            href="#about" 
            class="nav-link text-text-secondary hover:text-accent-primary font-medium transition-colors duration-200"
          >
            À propos
          </a>
        </li>
        <li>
          <a 
            href="#projects" 
            class="nav-link text-text-secondary hover:text-accent-primary font-medium transition-colors duration-200"
          >
            Projets
          </a>
        </li>
        <li>
          <a 
            href="#contact" 
            class="nav-link text-text-secondary hover:text-accent-primary font-medium transition-colors duration-200"
          >
            Contact
          </a>
        </li>
      </ul>

      <!-- CTA Button -->
      <a 
        href="#contact" 
        class="cta-nav hidden md:inline-block px-6 py-2 bg-accent-primary text-white rounded-lg font-medium
               hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200"
      >
        Travaillons ensemble
      </a>

      <!-- Mobile Menu Button (placeholder) -->
      <button 
        class="mobile-menu-button md:hidden p-2 text-text-primary hover:text-accent-primary"
        aria-label="Menu de navigation"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Spacer to prevent content from going under fixed header -->
<div class="header-spacer h-16"></div>

<style>
  .header {
    transition: all 0.3s ease;
  }

  /* Underline effect on nav links */
  .nav-link {
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-primary);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .header,
    .nav-link::after,
    .cta-nav {
      transition: none;
    }
  }
</style>
