---
// Footer - Simple & Clean
const currentYear = new Date().getFullYear();
---

<footer class="footer bg-gray-900 text-gray-300 py-12 px-6">
  <div class="container mx-auto max-w-6xl">
    <div class="footer-content grid md:grid-cols-3 gap-8 mb-8">
      <!-- About Column -->
      <div class="footer-section">
        <h3 class="text-white font-bold text-lg mb-4">Isabelle Lafont-Bertrand</h3>
        <p class="text-sm leading-relaxed">
          Développeuse Rails avec une mission : rendre le web accessible à tous.
        </p>
      </div>

      <!-- Quick Links Column -->
      <div class="footer-section">
        <h3 class="text-white font-bold text-lg mb-4">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="#about" class="hover:text-accent-primary transition-colors duration-200">
              À propos
            </a>
          </li>
          <li>
            <a href="#projects" class="hover:text-accent-primary transition-colors duration-200">
              Projets
            </a>
          </li>
          <li>
            <a href="#contact" class="hover:text-accent-primary transition-colors duration-200">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Column -->
      <div class="footer-section">
        <h3 class="text-white font-bold text-lg mb-4">Contact</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a 
              href="mailto:isabelle@example.com" 
              class="hover:text-accent-primary transition-colors duration-200"
            >
              isabelle@example.com
            </a>
          </li>
          <li>
            <a 
              href="https://github.com/Isalafont" 
              class="hover:text-accent-primary transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              title="Voir mon profil GitHub (ouvre dans un nouvel onglet)"
            >
              GitHub
            </a>
          </li>
          <li>
            <a 
              href="https://www.linkedin.com/in/isabelle-lafont/" 
              class="hover:text-accent-primary transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              title="Voir mon profil LinkedIn (ouvre dans un nouvel onglet)"
            >
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
      <p>
        © {currentYear} Isabelle Lafont-Bertrand. Tous droits réservés.
      </p>
      
      <p class="flex items-center gap-2">
        Fait avec <span class="text-red-500" aria-hidden="true">❤️</span> et 
        <a 
          href="https://astro.build" 
          class="text-accent-primary hover:underline"
          target="_blank"
          rel="noopener noreferrer"
          title="Découvrir Astro (ouvre dans un nouvel onglet)"
        >
          Astro
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  @media (prefers-reduced-motion: reduce) {
    .footer a {
      transition: none;
    }
  }
</style>
