---
const { question, options, correctAnswer, explanation } = Astro.props;
---

<div class="rgaa-challenger-card p-6 bg-white border-2 border-blue-100 rounded-xl shadow-sm mb-6" data-correct={correctAnswer}>
  <h3 class="text-lg font-bold text-blue-900 mb-4">{question}</h3>
  
  <div class="grid gap-3 mb-4">
    {options.map((option, index) => (
      <button 
        class="quiz-option w-full text-left p-3 rounded-lg border border-gray-200 hover:border-blue-400 hover:bg-blue-50 transition-colors focus:ring-2 focus:ring-blue-500 focus:outline-none"
        data-index={index}
      >
        {option}
      </button>
    ))}
  </div>

  <div class="quiz-feedback hidden mt-4 p-4 rounded-lg">
    <p class="feedback-text font-bold mb-2"></p>
    <p class="explanation-text text-sm text-gray-700">{explanation}</p>
  </div>
</div>

<script>
  function setupQuiz() {
    const cards = document.querySelectorAll('.rgaa-challenger-card');
    
    cards.forEach(card => {
      const options = card.querySelectorAll('.quiz-option');
      const feedback = card.querySelector('.quiz-feedback');
      const feedbackText = card.querySelector('.feedback-text');
      const correctAnswer = parseInt(card.getAttribute('data-correct'));

      options.forEach(option => {
        option.addEventListener('click', () => {
          const selectedIndex = parseInt(option.getAttribute('data-index'));
          
          // Disable all options
          options.forEach(opt => opt.disabled = true);
          
          feedback.classList.remove('hidden');
          
          if (selectedIndex === correctAnswer) {
            option.classList.add('bg-green-100', 'border-green-500', 'text-green-800');
            feedback.classList.add('bg-green-50', 'border', 'border-green-200');
            feedbackText.textContent = "✅ Correct !";
            feedbackText.classList.add('text-green-700');
          } else {
            option.classList.add('bg-red-100', 'border-red-500', 'text-red-800');
            feedback.classList.add('bg-red-50', 'border', 'border-red-200');
            feedbackText.textContent = "❌ Incorrect";
            feedbackText.classList.add('text-red-700');
            
            // Highlight the correct one
            options[correctAnswer].classList.add('ring-2', 'ring-green-500');
          }
        });
      });
    });
  }

  // Support Astro view transitions
  setupQuiz();
  document.addEventListener('astro:after-swap', setupQuiz);
</script>
