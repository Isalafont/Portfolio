---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('writing');
const articles = allArticles
  .filter(a => !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Writing – Isabelle Lafont-Bertrand">
  <div class="container">
    <Nav />

    <section aria-labelledby="writing-heading">
      <h1 id="writing-heading">Writing</h1>

      <ul role="list" class="articles-list">
        {articles.map(article => (
          <li>
            <article>
              <a href={`/writing/${article.slug}`} class="article-link">
                {article.data.title}
              </a>
              <span class="meta">
                {new Date(article.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
              </span>
            </article>
          </li>
        ))}
      </ul>
    </section>

    <footer>
      <p>Isabelle Lafont-Bertrand</p>
    </footer>
  </div>
</Layout>

<style>
  .container { padding-bottom: 4rem; }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .articles-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  article {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .article-link {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.4;
    text-decoration: none;
    color: var(--text);
  }

  a.article-link:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .meta {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>
