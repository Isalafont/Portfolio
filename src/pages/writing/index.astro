---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Writing – Isabelle Lafont-Bertrand" description="Articles sur Rails, l'accessibilité RGAA, et le dev gov.">
  <div class="container">
    <nav>
      <a href="/">← Isabelle Lafont-Bertrand</a>
    </nav>
    <section>
      <h1>Writing</h1>
      {posts.length === 0 ? (
        <p class="empty">Les articles arrivent bientôt.</p>
      ) : (
        <ul role="list">
          {posts.map(post => (
            <li>
              <article>
                <a href={`/writing/${post.slug}`}>{post.data.title}</a>
                <time datetime={post.data.date} class="meta">
                  {new Date(post.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
                </time>
              </article>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</Layout>

<style>
  .container { padding-top: 4rem; padding-bottom: 4rem; }
  nav { margin-bottom: 3rem; }
  nav a { font-size: 0.85rem; color: var(--muted); text-decoration: none; }
  nav a:hover { color: var(--text); }
  h1 { font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; font-family: 'Inter', sans-serif; font-weight: 500; color: var(--muted); margin-bottom: 2rem; }
  ul { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
  article { display: flex; justify-content: space-between; align-items: baseline; gap: 1.5rem; }
  article a { font-family: 'Lora', Georgia, serif; font-size: 1.1rem; text-decoration: none; line-height: 1.4; }
  article a:hover { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .meta { font-size: 0.8rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }
  .empty { color: var(--muted); font-style: italic; }
</style>
