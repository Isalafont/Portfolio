---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Writing – Isabelle Lafont" description="Articles sur le développement Rails et l'accessibilité RGAA.">
  <div class="container py-24">
    <header class="mb-16">
      <nav class="mb-8">
        <a href="/" class="text-sm font-bold uppercase tracking-widest no-underline opacity-50 hover:opacity-100 transition-opacity">← Isabelle Lafont</a>
      </nav>
      <h1 class="text-6xl font-extrabold tracking-tighter">Writing</h1>
    </header>

    <section>
      {posts.length === 0 ? (
        <p class="text-gray-400">Les articles arrivent bientôt.</p>
      ) : (
        <ul role="list" class="space-y-12 list-none p-0">
          {posts.map(post => (
            <li class="group">
              <article>
                <time datetime={post.data.date} class="block text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">
                  {new Date(post.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h2 class="text-3xl font-bold mb-3">
                  <a href={`/writing/${post.id}`} class="no-underline hover:text-blue-600 transition-colors">{post.data.title}</a>
                </h2>
                <p class="text-lg text-gray-500 max-w-2xl">{post.data.description}</p>
              </article>
            </li>
          ))}
        </ul>
      )}
    </section>

    <footer class="mt-32 opacity-20 text-xs font-bold uppercase tracking-widest">
      <p>© 2026 Isabelle Lafont — Code & Inclusion.</p>
    </footer>
  </div>
</Layout>
