---
import Layout from '../layouts/Layout.astro';
import Accordion from '../components/a11y/Accordion.astro';
import AccordionItem from '../components/a11y/AccordionItem.astro';
---

<Layout title="Expertise & Services — Isabelle Lafont">
  <div class="container">
    
    <nav aria-label="Navigation secondaire">
      <a href="/">← Retour Home</a>
    </nav>

    <header class="page-header">
      <p class="overline">Expertise</p>
      <h1>Services Accessibilité</h1>
      <p class="intro">
        J'accompagne les équipes produit et les institutions dans la création d'interfaces inclusives, 
        de l'audit initial au déploiement de composants haute-performance.
      </p>
    </header>

    <section class="services-list" aria-label="Liste des prestations">
      <Accordion>
        <AccordionItem title="Audit & Diagnostic RGAA" id="audit">
          <p>Analyse complète de vos interfaces selon le référentiel général d'amélioration de l'accessibilité.</p>
          <ul>
            <li>Audit de conformité (grille de test officielle)</li>
            <li>Rapport détaillé avec recommandations techniques exploitables</li>
            <li>Priorisation des corrections (Roadmap de mise en conformité)</li>
          </ul>
        </AccordionItem>

        <AccordionItem title="Développement & Remédiation" id="dev">
          <p>Mise en œuvre des corrections techniques et création de composants sur-mesure.</p>
          <ul>
            <li>Intégration de patterns ARIA complexes (Modales, Combobox, Sliders)</li>
            <li>Optimisation des parcours Utilisateur (Focus management, Screen readers)</li>
            <li>Standardisation de votre Design System accessible</li>
          </ul>
        </AccordionItem>

        <AccordionItem title="Accompagnement Stratégique" id="conseil">
          <p>Parce que l'accessibilité est un sujet transverse, j'aide vos équipes à monter en compétence.</p>
          <ul>
            <li>Formation technique pour les développeurs (Ruby, Rails, JS)</li>
            <li>Ateliers de sensibilisation pour les Product Owners et Designers</li>
            <li>Mise en place de tests automatisés d'accessibilité (CI/CD)</li>
          </ul>
        </AccordionItem>
      </Accordion>
    </section>

    <section class="cta-section">
      <h2>Collaborer sur un projet ?</h2>
      <p>Vous avez un besoin urgent de mise en conformité ou vous lancez un nouveau produit inclusif ?</p>
      <a href="mailto:isabelle@example.com" class="button">Discuter de votre projet</a>
    </section>

  </div>
</Layout>

<style>
  nav {
    margin-bottom: 3rem;
  }

  nav a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .overline {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-top: 0;
  }

  .intro {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 60ch;
  }

  .services-list {
    margin-bottom: 4rem;
  }

  ul {
    padding-left: 1.5rem;
    margin-top: 1rem;
  }

  li {
    margin-bottom: 0.5rem;
  }

  .cta-section {
    margin-top: 6rem;
    padding: 3rem;
    background: white;
    border-radius: 1rem;
    box-shadow: var(--shadow);
    text-align: center;
  }

  .cta-section h2 {
    margin-top: 0;
  }

  .button {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 1rem 2rem;
    background: var(--accent);
    color: white;
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 700;
  }

  .button:hover {
    opacity: 0.8;
  }
</style>
