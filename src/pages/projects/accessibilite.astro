---
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/a11y/QuizCard.astro';

const quizzes = [
  {
    question: "Dans un formulaire, quelle technique est obligatoire pour rendre un champ de saisie accessible (Critère 11.2) ?",
    options: [
      "Utiliser un attribut placeholder descriptif",
      "Utiliser un attribut title uniquement",
      "Utiliser un élément <label> visible et lié par for/id",
      "Mettre une icône descriptive à côté du champ"
    ],
    correctAnswer: 2,
    explanation: "Le placeholder n'est pas suffisant car il disparaît dès la saisie. Un label visible est indispensable pour la mémoire de travail et la navigation vocale."
  },
  {
    question: "Pour un tableau de données complexe avec plusieurs niveaux d'en-têtes, quelle méthode est indispensable (Critère 1.6) ?",
    options: [
      "Utiliser scope=\"col\" sur tous les en-têtes",
      "Utiliser le couple id / headers",
      "Doubler le tableau en version texte",
      "Utiliser aria-label sur chaque cellule"
    ],
    correctAnswer: 1,
    explanation: "Dès que le tableau possède des en-têtes qui ne s'appliquent pas à toute la ligne ou colonne, scope est insuffisant. id et headers permettent de lier précisément chaque cellule à ses parents."
  },
  {
    question: "Quelle est la syntaxe correcte pour lier une cellule <td> à 3 en-têtes (th1, th2, th3) via l'attribut headers ?",
    options: [
      "headers=\"th1; th2; th3\"",
      "headers=\"th1, th2, th3\"",
      "headers=\"th1 th2 th3\" (espace simple)",
      "headers=\"[th1][th2][th3]\""
    ],
    correctAnswer: 2,
    explanation: "Les IDs dans l'attribut headers doivent être séparés par des ESPACES simples uniquement. Les virgules ou points-virgules rendent la relation invalide pour les lecteurs d'écran."
  }
];
---

<Layout title="RGAA Masterclass — Le Challenger">
	<main class="min-h-screen bg-[#FBFBFD] text-[#1D1D1F]">
		<div class="container mx-auto px-6 py-20 max-w-3xl">
			
			<header class="text-center mb-16 space-y-4">
				<h1 class="text-5xl md:text-6xl font-extrabold tracking-tight">RGAA <span class="text-blue-600">Quest</span>.</h1>
				<p class="text-xl md:text-2xl font-medium text-gray-500 max-w-2xl mx-auto">
					Maîtrisez l'accessibilité par la pratique. Une expérience conçue pour tester vos limites RGAA.
				</p>
			</header>

			<div class="space-y-12">
				{quizzes.map((quiz, index) => (
					<div class="relative group">
						<div class="absolute -left-12 top-0 hidden md:flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-400 font-bold text-sm border border-blue-100 group-hover:bg-blue-600 group-hover:text-white transition-all">
							{index + 1}
						</div>
						<QuizCard {...quiz} />
					</div>
				))}
			</div>

			<footer class="mt-24 text-center border-t border-gray-100 pt-12">
				<div class="inline-flex items-center space-x-2 bg-white px-4 py-2 rounded-full shadow-sm border border-gray-100">
					<span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
					<span class="text-sm font-semibold">22 questions supplémentaires en cours de forge par Data ✨</span>
				</div>
				<p class="mt-8 text-gray-400 text-sm">Design & Inclusion par Isabelle Lafont.</p>
			</footer>

		</div>
	</main>
</Layout>

<style is:global>
	/* Polissage style Apple pour les QuizCards */
	.rgaa-challenger-card {
		background: rgba(255, 255, 255, 0.8) !important;
		backdrop-filter: blur(20px) !important;
		border: 1px solid rgba(0, 0, 0, 0.05) !important;
		border-radius: 28px !important;
		padding: 40px !important;
		box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04) !important;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease !important;
	}

	.quiz-option {
		background: #F5F5F7 !important;
		border: none !important;
		border-radius: 18px !important;
		padding: 20px 24px !important;
		font-weight: 600 !important;
		color: #1D1D1F !important;
		margin-bottom: 4px !important;
	}

	.quiz-option:hover {
		background: #E8E8ED !important;
		transform: scale(1.02);
	}

	.quiz-option:active {
		transform: scale(0.98);
	}

	.quiz-feedback {
		border-radius: 20px !important;
		margin-top: 24px !important;
		padding: 24px !important;
	}
</style>
