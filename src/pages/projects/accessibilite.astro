---
import Layout from '../layouts/Layout.astro';
import QuizCard from '../../components/a11y/QuizCard.astro';

// On garde nos 3 questions actuelles, Data en rajoutera 22
const quizzes = [
  {
    question: "Quelle technique est impérative pour rendre un champ de saisie accessible aux lecteurs d'écran ?",
    options: [
      "Un placeholder explicite",
      "Un attribut title descriptif",
      "Un élément <label> lié par for/id",
      "Une icône informative"
    ],
    correctAnswer: 2,
    explanation: "Le placeholder n'est pas une alternative au label car il disparaît dès la saisie. Un label lié permet aussi d'agrandir la zone de clic."
  },
  {
    question: "Pour un tableau de données complexe, quelle méthode garantit une lecture logique des en-têtes ?",
    options: [
      "Utiliser scope=\"col\" partout",
      "Utiliser le couple id / headers",
      "Scinder le tableau en deux",
      "Ne rien faire, c'est géré nativement"
    ],
    correctAnswer: 1,
    explanation: "Dès que le tableau possède des en-têtes imbriqués ou intermédiaires, les attributs id et headers sont les seuls à garantir une relation sans ambiguïté."
  },
  {
    question: "Quelle est la syntaxe exacte pour lier une cellule à trois en-têtes : th1, th2 et th3 ?",
    options: [
      "headers=\"th1; th2; th3\"",
      "headers=\"th1, th2, th3\"",
      "headers=\"th1 th2 th3\"",
      "headers=\"[th1][th2][th3]\""
    ],
    correctAnswer: 2,
    explanation: "Les IDs doivent être listés et séparés par des espaces simples uniquement. L'ordre recommandé va du parent le plus éloigné au plus proche."
  }
];
---

<Layout title="RGAA Quest — Maîtrisez l'accessibilité">
	<main class="min-h-screen bg-[#FBFBFD] text-[#1D1D1F] overflow-x-hidden">
		
		<!-- Hero Section Apple Style -->
		<section class="relative pt-32 pb-20 px-6 overflow-hidden">
			<div class="container mx-auto max-w-5xl text-center">
				<div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-blue-100 text-blue-700 text-xs font-bold tracking-widest uppercase animate-fade-in">
					Challenger Interactif
				</div>
				<h1 class="text-6xl md:text-8xl font-extrabold tracking-tight mb-8 bg-gradient-to-b from-[#1D1D1F] to-[#424245] bg-clip-text text-transparent">
					RGAA <span class="text-blue-600">Quest</span>.
				</h1>
				<p class="text-2xl md:text-3xl font-medium text-[#86868B] max-w-3xl mx-auto leading-tight">
					Prêt à défier les critères ? Testez votre expertise accessibilité avec notre simulateur ultra-réaliste.
				</p>
			</div>
			
			<!-- Déco visuelle style Apple -->
			<div class="absolute top-0 right-0 -z-10 w-[600px] h-[600px] bg-blue-50/50 rounded-full blur-[120px] translate-x-1/2 -translate-y-1/2"></div>
			<div class="absolute bottom-0 left-0 -z-10 w-[400px] h-[400px] bg-indigo-50/50 rounded-full blur-[100px] -translate-x-1/2 translate-y-1/2"></div>
		</section>

		<!-- Quiz Stream -->
		<section class="px-6 pb-40">
			<div class="container mx-auto max-w-3xl">
				<div class="space-y-4">
					{quizzes.map((quiz) => (
						<QuizCard {...quiz} />
					))}
				</div>

				<!-- Coming Soon Indicator -->
				<div class="mt-20 p-12 text-center bg-white/40 border border-dashed border-gray-200 rounded-[32px] backdrop-blur-sm">
					<div class="inline-flex items-center space-x-3 mb-4">
						<span class="relative flex h-3 w-3">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-3 w-3 bg-blue-500"></span>
						</span>
						<span class="text-sm font-bold text-blue-600 uppercase tracking-widest">Forge en cours</span>
					</div>
					<h2 class="text-3xl font-bold mb-4 italic">Un déluge de questions arrive...</h2>
					<p class="text-lg text-gray-500">Notre agent Data ✨ prépare 22 nouveaux défis pour parfaire votre certification.</p>
				</div>
			</div>
		</section>

		<footer class="py-20 border-t border-gray-100/50 bg-white/50">
			<div class="container mx-auto max-w-3xl px-6 text-center">
				<p class="text-sm font-semibold text-gray-400">ISABELLE LAFONT — CODE & INCLUSION</p>
			</div>
		</footer>
	</main>
</Layout>

<style>
	@keyframes fade-in {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in {
		animation: fade-in 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}
</style>
