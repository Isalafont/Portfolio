---
import Layout from '../../layouts/Layout.astro';
import QuizCard from '../../components/a11y/QuizCard.astro';

const tickets = [
  {
    id: 'DP-1525',
    title: 'Mise en conformité API Entreprise',
    status: '🚧 In Progress',
    note: "Audit des pages publiques et corrections prioritaires (en cours)."
  },
  {
    id: 'DP-1668',
    title: 'Audit page Accessibilité',
    status: '✅ Complété',
    note: "10 critères non conformes identifiés et documentés."
  },
  {
    id: 'DP-1280',
    title: 'Accessibilité Clavier (Sauvegarder)',
    status: '📋 Todo',
    note: "Optimisation de l'interaction clavier sur le bouton principal."
  }
];

const quizzes = [
  {
    question: "Dans un formulaire, quelle technique est obligatoire pour rendre un champ de saisie accessible (Critère 11.2) ?",
    options: [
      "Utiliser un attribut placeholder descriptif",
      "Utiliser un attribut title uniquement",
      "Utiliser un élément <label> visible et lié par for/id",
      "Mettre une icône descriptive à côté du champ"
    ],
    correctAnswer: 2,
    explanation: "Le placeholder n'est pas suffisant car il disparaît dès la saisie. Un label visible est indispensable pour la mémoire de travail et la navigation vocale."
  },
  {
    question: "Pour un tableau de données complexe avec plusieurs niveaux d'en-têtes, comment lie-t-on les cellules aux en-têtes ?",
    options: [
      "Avec scope=\"col\" partout",
      "Avec les attributs id et headers",
      "Avec une balise <caption> descriptive",
      "C'est impossible, il faut scinder le tableau"
    ],
    correctAnswer: 1,
    explanation: "Les attributs id sur les <th> et headers sur les <td> sont obligatoires pour les relations complexes que scope ne peut pas gérer seul."
  }
];
---

<Layout title="Codex ARIA - Accessibilité RGAA">
	<main class="container mx-auto px-4 py-8 max-w-4xl">
		<h1 class="text-4xl font-bold mb-4">Codex ARIA — Accessibilité</h1>
		<p class="text-xl mb-8 text-gray-600">Mémoire technique et suivi de conformité RGAA 4.1 pour DataPass et Portfolio.</p>

		<section class="mb-12">
			<h2 class="text-2xl font-semibold mb-6">📘 Tickets DataPass & Études de Cas</h2>
			<div class="grid gap-4">
				{tickets.map(ticket => (
					<div class="border p-4 rounded-lg shadow-sm border-gray-200 bg-white">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-mono bg-blue-100 text-blue-800 px-2 py-1 rounded">{ticket.id}</span>
								<h3 class="text-lg font-bold mt-2">{ticket.title}</h3>
							</div>
							<span class="text-sm font-medium px-2 py-1 rounded bg-gray-100">{ticket.status}</span>
						</div>
						<p class="text-gray-600 mt-2">{ticket.note}</p>
					</div>
				))}
			</div>
		</section>

		<section class="mb-12">
			<h2 class="text-2xl font-semibold mb-6 italic text-blue-800">🚀 RGAA Challenger (Quiz Interactif)</h2>
			<p class="mb-6 text-gray-600">Entraînez-vous sur des cas réels RGAA rencontrés lors de mes missions.</p>
			
			<div class="space-y-6">
				{quizzes.map(quiz => (
					<QuizCard {...quiz} />
				))}
			</div>
		</section>

		<section class="bg-blue-50 p-6 rounded-xl border border-blue-200">
			<h2 class="text-xl font-semibold mb-2">Prochaine étape</h2>
			<p>Publication de l'article d'expertise complet avec démonstration de l'Inspecteur A11y.</p>
		</section>
	</main>
</Layout>
