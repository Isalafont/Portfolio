---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const projects = [
  {
    name: "DataPass",
    url: "https://datapass.api.gouv.fr",
    description: "Plateforme gouvernementale d'habilitations pour les API publiques françaises. OpenSource, à la DINUM.",
    stack: ["Rails", "PostgreSQL", "Hotwire"],
    status: "En production",
  },
  {
    name: "ImmoTracker",
    url: null,
    description: "Outil de recherche immobilière intelligente. Agrège les annonces, alerte sur les nouvelles opportunités.",
    stack: ["Rails", "Mapbox", "TailwindCSS"],
    status: "En développement",
  },
];
---

<Layout title="Projets – Isabelle Lafont-Bertrand">
  <div class="container">
    <Nav />

    <section aria-labelledby="projects-heading">
      <h1 id="projects-heading">Projets</h1>

      <ul role="list" class="projects-list">
        {projects.map(project => (
          <li>
            <article>
              <div class="project-header">
                <h2>
                  {project.url
                    ? <a href={project.url} target="_blank" rel="noopener">{project.name}</a>
                    : project.name
                  }
                </h2>
                <span class="status">{project.status}</span>
              </div>
              <p>{project.description}</p>
              <ul class="stack" role="list" aria-label="Stack technique">
                {project.stack.map(tech => <li>{tech}</li>)}
              </ul>
            </article>
          </li>
        ))}
      </ul>
    </section>

    <footer>
      <p>Isabelle Lafont-Bertrand</p>
    </footer>
  </div>
</Layout>

<style>
  .container { padding-bottom: 4rem; }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .projects-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  h2 {
    font-size: 1.1rem;
  }

  h2 a {
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .status {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: 'Inter', sans-serif;
  }

  p {
    color: var(--text);
    font-size: 0.95rem;
    max-width: 480px;
    margin-bottom: 0.75rem;
  }

  .stack {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .stack li {
    font-size: 0.78rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--muted);
    background: var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>
