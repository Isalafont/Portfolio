---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const projects = [
  {
    name: "DataPass",
    url: "https://datapass.api.gouv.fr",
    description: "Plateforme gouvernementale d'habilitations pour les API publiques françaises. OpenSource, à la DINUM.",
    stack: ["Rails", "PostgreSQL", "Hotwire"],
    status: "Active",
  },
  {
    name: "RGAA Quest",
    url: "/projects/accessibilite",
    description: "Challenge interactif pour tester son expertise sur les critères RGAA 4.1. Un simulateur ludique pour la certification.",
    stack: ["Astro 6", "TailwindCSS", "A11y"],
    status: "Nouveau ✨",
    internal: true
  },
  {
    name: "ImmoTracker",
    url: null,
    description: "Outil de recherche immobilière intelligente. Agrège les annonces, alerte sur les nouvelles opportunités.",
    stack: ["Rails", "Mapbox", "TailwindCSS"],
    status: "Dev",
  },
];
---

<Layout title="Projets – Isabelle Lafont">
  <div class="container">
    <Nav />

    <section aria-labelledby="projects-heading">
      <h1 id="projects-heading" class="mb-16 text-3xl font-extrabold tracking-tight">Projets Prioritaires</h1>

      <ul role="list" class="projects-list">
        {projects.map(project => (
          <li>
            <article class="group relative bg-white p-8 rounded-[24px] shadow-[0_4px_20px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] transition-all duration-300 border border-black/[0.03]">
              <div class="project-header mb-6">
                <h2 class="text-xl font-bold">
                  {project.url
                    ? <a href={project.url} class="after:absolute after:inset-0" target={project.internal ? undefined : "_blank"} rel={project.internal ? undefined : "noopener"}>{project.name}</a>
                    : project.name
                  }
                </h2>
                <span class="status bg-gray-50 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider text-gray-500">{project.status}</span>
              </div>
              <p class="text-gray-600 leading-relaxed mb-6 max-w-md">{project.description}</p>
              <ul class="stack" role="list" aria-label="Stack technique">
                {project.stack.map(tech => <li class="text-[0.7rem] font-bold uppercase tracking-widest text-blue-500/70">{tech}</li>)}
              </ul>
            </article>
          </li>
        ))}
      </ul>
    </section>

    <footer class="mt-32 text-center opacity-30">
      <p>Isabelle Lafont — Code & Inclusion</p>
    </footer>
  </div>
</Layout>

<style>
  .projects-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  h2 a {
    text-decoration: none;
  }

  .stack {
    list-style: none;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
