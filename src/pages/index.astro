---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Isabelle Lafont-Bertrand – Développeuse Rails">
  <div class="container">

    <nav aria-label="Navigation principale">
      <a href="/writing">Writing</a>
      <a href="/services">Services</a>
      <a href="/projects">Projects</a>
    </nav>

    <section class="bio" aria-labelledby="bio-heading">
      <h1 id="bio-heading">Isabelle Lafont-Bertrand</h1>

      <p>
        Je construis des applications web accessibles chez <a href="https://datapass.api.gouv.fr" target="_blank" rel="noopener">DataPass</a>,
        une plateforme gouvernementale OpenSource à la DINUM.
      </p>
      <p>
        Je pense à l'accessibilité même quand je devrais penser à autre chose.
        Rails, Ruby, RGAA — et en ce moment, l'intersection entre IA et développement gouvernemental.
      </p>

      <div class="links" role="list" aria-label="Liens externes">
        <a href="https://github.com/Isalafont" target="_blank" rel="noopener" role="listitem">GitHub</a>
        <span aria-hidden="true">·</span>
        <a href="https://www.linkedin.com/in/isabelle-lafont/" target="_blank" rel="noopener" role="listitem">LinkedIn</a>
      </div>
    </section>

    <footer>
      <p>Isabelle Lafont-Bertrand</p>
    </footer>

  </div>
</Layout>

<style>
  .container {
    padding-top: 2.5rem;
    padding-bottom: 4rem;
  }

  nav {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  nav a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
  }

  nav a:hover {
    color: var(--text);
  }

  .bio h1 {
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
    font-family: 'Lora', Georgia, serif;
  }

  .bio p {
    max-width: 520px;
    color: var(--text);
  }

  .links {
    margin-top: 1.75rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.9rem;
  }

  .links span { color: var(--muted); }

  .links a {
    text-decoration: none;
    color: var(--muted);
  }

  .links a:hover { color: var(--accent); }

  footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>
