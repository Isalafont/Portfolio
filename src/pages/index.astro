---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Isabelle Lafont — Experte Accessibilité & Développeuse Fullstack">
  <div class="container">

    <nav aria-label="Navigation principale">
      <a href="/services/">Expertise</a>
      <a href="/projects/">Projets</a>
      <a href="/writing/">Blog</a>
    </nav>

    <section class="bio" aria-labelledby="bio-heading">
      <h1 id="bio-heading">Je bâtis des produits web que tout le monde peut utiliser.</h1>

      <p class="intro">
        Je suis <strong>Isabelle Lafont</strong>. Développeuse Fullstack & Experte Accessibilité (RGAA). 
        J’allie la puissance de Ruby on Rails à une rigueur inclusive pour créer des expériences numériques sans barrières.
      </p>

      <p>
        Actuellement, je renforce l'accessibilité chez <a href="https://datapass.api.gouv.fr" target="_blank" rel="noopener">DataPass</a> (DINUM), 
        tout en préparant ma certification RGAA (prévue le 22 mai).
      </p>

      <div class="action-box">
        <h3>Codex ARIA</h3>
        <p>Découvrez ma bibliothèque de patterns accessibles haute-performance.</p>
        <a href="/projects/accessibilite/" class="cta-link">Consulter le Codex →</a>
      </div>

      <div class="links" role="list" aria-label="Liens externes">
        <a href="https://github.com/Isalafont" target="_blank" rel="noopener" role="listitem">GitHub</a>
        <span aria-hidden="true">·</span>
        <a href="https://www.linkedin.com/in/isabelle-lafont/" target="_blank" rel="noopener" role="listitem">LinkedIn</a>
      </div>
    </section>

    <footer>
      <p>© 2026 Isabelle Lafont — Code & Inclusion.</p>
    </footer>

  </div>
</Layout>

<style>
  nav {
    display: flex;
    gap: 2rem;
    margin-bottom: 5rem;
  }

  nav a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  nav a:hover {
    color: var(--accent);
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: var(--text);
    max-width: 15ch;
  }

  .intro {
    font-size: 1.25rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .action-box {
    margin-top: 4rem;
    padding: 2rem;
    background: white;
    border-radius: 1rem;
    box-shadow: var(--shadow);
  }

  .action-box h3 {
    margin-top: 0;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .action-box p {
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .cta-link {
    font-weight: 700;
    text-decoration: none;
  }

  .links {
    margin-top: 3rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 1rem;
  }

  .links span { color: var(--muted); }

  .links a {
    text-decoration: none;
    color: var(--muted);
  }

  .links a:hover { color: var(--accent); }

  footer {
    margin-top: 8rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>
