---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Isabelle Lafont — Développeuse & Experte RGAA">
  <main>
    <header>
      <div class="hero-content">
        <div class="kicker">Développeuse Ruby on Rails <span>&</span> Experte RGAA</div>
        <h1>Isabelle Lafont</h1>
        <p>
          Développeuse Fullstack passionnée par l'accessibilité numérique et l'IA. 
          J'accompagne les projets à impact, comme <strong>DataPass</strong> (BetaGouv), 
          pour construire un web plus inclusif et performant.
        </p>

        <div class="contact-chips">
          <span class="location" role="img" aria-label="Localisation">📍 Paris - Romainville</span>
          <a href="mailto:isabelle.lafont@gmail.com" class="email">📧 Me contacter</a>
        </div>
      </div>

      <div class="hero-visual">
        <img src="/profile.png" alt="Illustration graphique d'Isabelle" class="profile-avatar" />
      </div>
    </header>

    <section class="projects-preview">
      <div class="card">
        <h2>RGAA Run</h2>
        <p>Challenge ton accessibilité avec notre nouveau module interactif.</p>
        <a href="/projects/accessibilite">Relever le défi →</a>
      </div>
    </section>

    <footer>
      <div class="status">
        <span class="dot"></span> Open aux collaborations (Inclusion & IA)
      </div>
      <div class="links">
        <a href="https://github.com/Isalafont">GitHub</a>
        <a href="https://twitter.com/Isalafont">Twitter</a>
      </div>
      <p class="credits">© 2026 Isabelle Lafont — Code & Inclusion.</p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  header {
    display: flex;
    flex-direction: column-reverse;
    gap: 2rem;
    margin-bottom: 5rem;
  }

  @media (min-width: 768px) {
    header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .hero-content {
    flex: 1;
  }

  .hero-visual {
    flex-shrink: 0;
    width: 200px;
    height: auto;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .hero-visual {
      margin: 0;
    }
  }

  .profile-avatar {
    width: 100%;
    height: auto;
    filter: drop-shadow(var(--shadow));
  }

  .kicker {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .kicker span {
    color: var(--accent);
  }

  h1 {
    font-size: 2.5rem;
    color: var(--text);
    margin-bottom: 2rem;
    max-width: 15ch;
  }

  p {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: var(--text-soft);
  }

  .projects-preview .card {
    background: white;
    padding: 2rem;
    border-radius: 1rem;
    box-shadow: var(--shadow);
    margin-top: 4rem;
  }

  .projects-preview h2 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }

  .projects-preview p {
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .projects-preview a {
    font-weight: 700;
    text-decoration: none;
    color: var(--accent);
  }

  .contact-chips {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 3rem;
    font-size: 1rem;
  }

  .contact-chips .location {
    color: var(--muted);
  }

  .contact-chips .email {
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    border-bottom: 2px solid var(--accent);
  }

  .contact-chips .email:hover {
    background: var(--accent-light);
  }

  footer {
    margin-top: 8rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.85rem;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    display: inline-block;
  }

  .links {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .links a {
    color: var(--muted);
    text-decoration: none;
  }

  .links a:hover {
    color: var(--text);
  }
</style>
